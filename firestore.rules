rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.3 Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Worlds
    match /worlds/{worldId} {
      function isValidWorld(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
            && data.ownerId == request.auth.uid
            && data.createdAt == request.time;
      }

      allow read: if isSignedIn() && (existing().isPublic == true || existing().ownerId == request.auth.uid);
      allow create: if isSignedIn() && isValidWorld(incoming()) && isValidId(worldId);
      allow update: if isOwner(existing().ownerId) 
                   && incoming().ownerId == existing().ownerId
                   && incoming().updatedAt == request.time;
      allow delete: if isOwner(existing().ownerId);

      // Sub-collections
      match /objects/{objectId} {
        function isValidObject(data) {
          return data.type in ['box', 'sphere', 'cylinder', 'torus', 'plane', 'light', 'model']
              && data.position is map
              && data.createdBy == request.auth.uid;
        }

        // Access derived from parent world readability
        allow read: if get(/databases/$(database)/documents/worlds/$(worldId)).data.isPublic == true 
                   || get(/databases/$(database)/documents/worlds/$(worldId)).data.ownerId == request.auth.uid;
        
        // Collaboration: Anyone signed in can contribute to a public world? 
        // Let's restrict to owner for now, or world members if we implemented it.
        // For "VR World Creator", let's allow "World Members" write.
        allow create, update, delete: if isSignedIn() && (
          get(/databases/$(database)/documents/worlds/$(worldId)).data.ownerId == request.auth.uid
        );
      }

      match /collaborators/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // 2. Marketplace
    match /marketplace/{assetId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().creatorId == request.auth.uid;
      allow update, delete: if isOwner(existing().creatorId);
    }
  }
}
